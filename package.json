{
  "name": "custom-wysiwyg-editor",
  "version": "0.2.0",
  "private": true,
  "description": "A framework-agnostic WYSIWYG editor with first-class React/Next.js bindings and Markdown/HTML export",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @custom-wysiwyg/core -w @custom-wysiwyg/ui -w @custom-wysiwyg/export-html -w @custom-wysiwyg/export-markdown -w @custom-wysiwyg/react",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "happy-dom": "^18.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
