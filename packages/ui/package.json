{
  "name": "@custom-wysiwyg/ui",
  "version": "0.2.3",
  "description": "Notion-style UI widgets for @custom-wysiwyg/core: bubble toolbar, slash menu. Framework-free DOM components",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@custom-wysiwyg/core": "*"
  },
  "license": "MIT"
}
