{
  "name": "@custom-wysiwyg/ui",
  "version": "0.2.5",
  "description": "Notion-style UI widgets for @custom-wysiwyg/core: bubble toolbar, slash menu. Framework-free DOM components",
  "keywords": [
    "wysiwyg",
    "editor",
    "toolbar",
    "slash-menu",
    "notion"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mostlytricks/custom-wysiwyg-editor.git",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/mostlytricks/custom-wysiwyg-editor/tree/main/packages/ui#readme",
  "bugs": "https://github.com/mostlytricks/custom-wysiwyg-editor/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@custom-wysiwyg/core": "^0.2.5"
  }
}
