{
  "name": "@custom-wysiwyg/core",
  "version": "0.2.2",
  "description": "Framework-agnostic WYSIWYG editor core: JSON document model, transactions, and a contenteditable view",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "wysiwyg",
    "editor",
    "contenteditable",
    "rich-text"
  ],
  "license": "MIT"
}
