{
  "name": "@custom-wysiwyg/core",
  "version": "0.2.4",
  "description": "Framework-agnostic WYSIWYG editor core: JSON document model, transactions, and a contenteditable view",
  "keywords": [
    "wysiwyg",
    "editor",
    "contenteditable",
    "rich-text"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mostlytricks/custom-wysiwyg-editor.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/mostlytricks/custom-wysiwyg-editor/tree/main/packages/core#readme",
  "bugs": "https://github.com/mostlytricks/custom-wysiwyg-editor/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  }
}
