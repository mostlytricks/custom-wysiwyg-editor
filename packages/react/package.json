{
  "name": "@custom-wysiwyg/react",
  "version": "0.2.4",
  "description": "React bindings for @custom-wysiwyg/core — SSR-safe, App Router ready",
  "keywords": [
    "wysiwyg",
    "editor",
    "react",
    "nextjs",
    "rich-text"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mostlytricks/custom-wysiwyg-editor.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/mostlytricks/custom-wysiwyg-editor/tree/main/packages/react#readme",
  "bugs": "https://github.com/mostlytricks/custom-wysiwyg-editor/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@custom-wysiwyg/core": "^0.2.4",
    "@custom-wysiwyg/ui": "^0.2.4"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
