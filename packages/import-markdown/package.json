{
  "name": "@custom-wysiwyg/import-markdown",
  "version": "0.2.4",
  "description": "Parse Markdown (the GFM subset the editor exports) into @custom-wysiwyg/core documents",
  "keywords": [
    "wysiwyg",
    "editor",
    "markdown",
    "gfm",
    "parser"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mostlytricks/custom-wysiwyg-editor.git",
    "directory": "packages/import-markdown"
  },
  "homepage": "https://github.com/mostlytricks/custom-wysiwyg-editor/tree/main/packages/import-markdown#readme",
  "bugs": "https://github.com/mostlytricks/custom-wysiwyg-editor/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@custom-wysiwyg/core": "^0.2.4"
  }
}
