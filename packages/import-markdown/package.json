{
  "name": "@custom-wysiwyg/import-markdown",
  "version": "0.2.1",
  "description": "Parse Markdown (the GFM subset the editor exports) into @custom-wysiwyg/core documents",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@custom-wysiwyg/core": "*"
  },
  "license": "MIT"
}
