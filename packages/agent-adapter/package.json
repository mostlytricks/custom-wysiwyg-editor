{
  "name": "@custom-wysiwyg/agent-adapter",
  "version": "0.2.5",
  "description": "The agent seam for @custom-wysiwyg/core: markdown context out, undoable markdown/block edits in, block-buffered streaming",
  "keywords": [
    "wysiwyg",
    "editor",
    "ai",
    "agent",
    "llm"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mostlytricks/custom-wysiwyg-editor.git",
    "directory": "packages/agent-adapter"
  },
  "homepage": "https://github.com/mostlytricks/custom-wysiwyg-editor/tree/main/packages/agent-adapter#readme",
  "bugs": "https://github.com/mostlytricks/custom-wysiwyg-editor/issues",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@custom-wysiwyg/core": "^0.2.5",
    "@custom-wysiwyg/export-markdown": "^0.2.5",
    "@custom-wysiwyg/import-markdown": "^0.2.5"
  }
}
